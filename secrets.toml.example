# .streamlit/secrets.toml
# 貼到 Streamlit Cloud → App Settings → Secrets

# Telegram (可選)
TELEGRAM_BOT_TOKEN = "你的_BOT_TOKEN"
TELEGRAM_CHAT_ID   = "你的_CHAT_ID"

# Alpha Vantage - 免費 500次/天
# 申請: https://www.alphavantage.co/support/#api-key (填 email 即得)
ALPHA_VANTAGE_KEY = "你的_AV_KEY"

# Finnhub - 免費 60次/分鐘
# 申請: https://finnhub.io/register
FINNHUB_KEY = "你的_FH_KEY"
